{
  "name": "omp-impeccable",
  "version": "0.1.0",
  "description": "Run Impeccable skills from OMP without blocking the agent.",
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jenkei/omp-impeccable.git"
  },
  "bugs": {
    "url": "https://github.com/jenkei/omp-impeccable/issues"
  },
  "homepage": "https://github.com/jenkei/omp-impeccable#readme",
  "keywords": [
    "omp-plugin",
    "omp",
    "impeccable",
    "design"
  ],
  "files": [
    "extensions/",
    "docs/images/omp-impeccable.svg",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=24"
  },
  "omp": {
    "name": "Impeccable for OMP",
    "description": "Run Impeccable skills from OMP without blocking the agent.",
    "extensions": [
      "./extensions/impeccable.ts"
    ]
  },
  "dependencies": {
    "impeccable": "*"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@oh-my-pi/pi-coding-agent": "*",
    "@types/node": "24.13.2",
    "typescript": "6.0.3",
    "vitest": "^4.1.9"
  },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "format": "biome check --write .",
    "format:check": "biome check .",
    "check": "pnpm typecheck && pnpm format:check && pnpm test",
    "pack:check": "npm pack --dry-run",
    "release:check": "pnpm check && pnpm pack:check"
  },
  "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26"
}
